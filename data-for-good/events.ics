BEGIN:VEVENT
SUMMARY:Fresque du Numérique
DTSTART;TZID=Europe/Paris:20260225T183000
DTEND;TZID=Europe/Paris:20260225T203000
UID:https://www.eventbrite.fr/e/fresque-du-numerique-x-data-for-good-borde
